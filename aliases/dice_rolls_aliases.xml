<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE MudletPackage>
<MudletPackage version="1.001">
	<TriggerPackage />
	<TimerPackage />
	<AliasPackage>
		<AliasGroup isActive="yes" isFolder="yes">
			<name>Dice rolls</name>
			<script></script>
			<command></command>
			<packageName></packageName>
			<regex></regex>
			<Alias isActive="yes" isFolder="no">
				<name>Dice help</name>
				<script>dice_rolls:echo(dice_rolls.help)</script>
				<command></command>
				<packageName></packageName>
				<regex>^dice help$</regex>
			</Alias>
			<Alias isActive="yes" isFolder="no">
				<name>Dice version</name>
				<script>dice_rolls:echo(f'version {dice_rolls.version}\n')</script>
				<command></command>
				<packageName></packageName>
				<regex>^dice version$</regex>
			</Alias>
			<Alias isActive="yes" isFolder="no">
				<name>Clear dice</name>
				<script>--syntax: dice clear
dice_rolls:clear()</script>
				<command></command>
				<packageName></packageName>
				<regex>^dice clear$</regex>
			</Alias>
			<Alias isActive="yes" isFolder="no">
				<name>Show dice</name>
				<script>--syntax: dice show
dice_rolls:show()</script>
				<command></command>
				<packageName></packageName>
				<regex>^dice show$</regex>
			</Alias>
			<Alias isActive="yes" isFolder="no">
				<name>Dice add</name>
				<script>--syntax: dice add name number

local name = matches[2]
local value = tonumber(matches[3])

dice_rolls:add(name, value)</script>
				<command></command>
				<packageName></packageName>
				<regex>^dice add (\S+) (\d+)$</regex>
			</Alias>
			<Alias isActive="yes" isFolder="no">
				<name>Dice remove</name>
				<script>local name = matches[2]

dice_rolls:remove(name)</script>
				<command></command>
				<packageName></packageName>
				<regex>^dice remove (\S+)$</regex>
			</Alias>
			<Alias isActive="yes" isFolder="no">
				<name>Dice pop</name>
				<script>local name = matches[2]

dice_rolls:pop(name)</script>
				<command></command>
				<packageName></packageName>
				<regex>^dice pop (\S+)$</regex>
			</Alias>
		</AliasGroup>
	</AliasPackage>
	<ActionPackage />
	<ScriptPackage />
	<KeyPackage />
	<HelpPackage>
		<helpURL></helpURL>
	</HelpPackage>
</MudletPackage>
